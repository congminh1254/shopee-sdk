{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/__tests__/**/*",
    "src/version.ts"
  ],
  "out": "docs/api",
  "name": "Shopee SDK API Reference",
  "includeVersion": true,
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeInternal": true,
  "theme": "default",
  "readme": "README.md",
  "githubPages": true,
  "cleanOutputDir": true
}
