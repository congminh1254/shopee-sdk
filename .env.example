# Shopee SDK Sandbox Integration Test Credentials
# Copy this file to '.env' and fill in your Shopee Open Platform Sandbox credentials.

# Your Shopee Open Platform Sandbox Partner Credentials
SHOPEE_SANDBOX_PARTNER_ID=your_sandbox_partner_id_here
SHOPEE_SANDBOX_PARTNER_KEY=your_sandbox_partner_key_here

# Your Shopee Sandbox Shop ID (Vietnam Local)
SHOPEE_SANDBOX_SHOP_ID=your_sandbox_shop_id_here

# Your Sandbox Seller Center / Shop Login Credentials (for Vietnam Local Sandbox)
# Required if you want to automate OAuth flow or generate manual link
SHOPEE_SANDBOX_ACCOUNT=your_sandbox_seller_username_or_email_here
SHOPEE_SANDBOX_PASSWORD=your_sandbox_seller_password_here

# Optional: Pre-existing access or refresh tokens to bypass OAuth flow and speed up tests
SHOPEE_SANDBOX_ACCESS_TOKEN=
SHOPEE_SANDBOX_REFRESH_TOKEN=
